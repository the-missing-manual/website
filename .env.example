# PostHog analytics (client-side).
#
# IMPORTANT: Waku only exposes env vars prefixed with WAKU_PUBLIC_ to the
# browser. Do NOT use a VITE_ prefix — Waku does not recognize it and the
# value will be `undefined` in the client bundle.
#
# Set these in your local .env AND in your Vercel project settings
# (Production + Preview), then rebuild/redeploy. Verify in the browser
# DevTools Network tab that requests to i.posthog.com fire on page load.

WAKU_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
WAKU_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com
